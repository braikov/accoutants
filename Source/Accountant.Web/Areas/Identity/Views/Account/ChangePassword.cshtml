@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Смяна на парола";
}

<div class="auth-card">
    <h1>Смяна на парола</h1>
    <p class="lead">Въведете текущата си парола и новата, която искате да зададете.</p>

    <form asp-action="ChangePassword" method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <div class="field">
            <label asp-for="CurrentPassword"></label>
            <input asp-for="CurrentPassword" autocomplete="current-password" autofocus />
            <span asp-validation-for="CurrentPassword" class="field-validation-error"></span>
        </div>

        <div class="field">
            <label asp-for="NewPassword"></label>
            <input asp-for="NewPassword" autocomplete="new-password" />
            <span asp-validation-for="NewPassword" class="field-validation-error"></span>
        </div>

        <div class="field">
            <label asp-for="ConfirmPassword"></label>
            <input asp-for="ConfirmPassword" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
        </div>

        <button type="submit" class="btn btn-primary">Смени паролата</button>
    </form>

    <div class="auth-meta">
        <a asp-area="App" asp-controller="Workspace" asp-action="Index">Назад към профила</a>
    </div>
</div>
