@model Accountant.Web.Areas.Administration.ViewModels.UsersListViewModel
@{
    ViewData["Title"] = "Потребители";
}

<h1 class="h4 mb-3">Потребители</h1>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light small">
                <tr>
                    <th>Email</th>
                    <th class="text-center">Email потв.</th>
                    <th class="text-center">Lockout</th>
                    <th class="text-end">Фирми</th>
                    <th class="text-end">Документи</th>
                    <th class="text-end">Токени</th>
                    <th class="text-end">USD</th>
                </tr>
            </thead>
            <tbody class="small">
                @foreach (var row in Model.Page.Items)
                {
                    <tr>
                        <td>@row.Email</td>
                        <td class="text-center">
                            @if (row.EmailConfirmed) { <span class="text-success">✓</span> } else { <span class="text-body-secondary">—</span> }
                        </td>
                        <td class="text-center">
                            @if (row.LockoutEndUtc is DateTime end && end > DateTime.UtcNow)
                            {
                                <span class="badge text-bg-danger">до @end.ToLocalTime().ToString("dd.MM HH:mm")</span>
                            }
                            else
                            {
                                <span class="text-body-secondary">—</span>
                            }
                        </td>
                        <td class="text-end">@row.TenantsCount</td>
                        <td class="text-end">@row.DocumentsCount.ToString("N0")</td>
                        <td class="text-end">@row.Tokens.ToString("N0")</td>
                        <td class="text-end">@row.CostUsd.ToString("0.0000")</td>
                    </tr>
                }
                @if (Model.Page.Items.Count == 0)
                {
                    <tr><td colspan="7" class="text-center text-body-secondary py-4">Няма потребители.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@await Html.PartialAsync("_Pager", (Model.Page.Page, Model.Page.TotalPages, Model.Page.TotalCount, (object)new { PageSize = Model.Page.PageSize }))
