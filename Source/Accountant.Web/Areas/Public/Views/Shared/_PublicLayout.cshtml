@{
    var title = ViewData["Title"] as string;
    var fullTitle = string.IsNullOrEmpty(title) ? "Accountant — AI за счетоводство" : $"{title} — Accountant";
}
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0f172a" />
    <meta name="description" content="AI автоматизация за счетоводни офиси — извличане на данни от фактури и касови бележки." />
    <title>@fullTitle</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="~/public/css/public.css" asp-append-version="true" />
</head>
<body>
    <a href="#main" class="skip-link">Към съдържанието</a>
    <header class="site-head">
        <div class="container head-inner">
            <a class="brand" href="/" aria-label="Accountant">
                <span class="brand-mark" aria-hidden="true">a.</span>
                <span class="brand-name">accountant</span>
            </a>
            <span class="badge">Coming soon</span>
            <nav class="head-auth" aria-label="Акаунт">
                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <a class="head-auth-link head-auth-link-primary" asp-area="App" asp-controller="Workspace" asp-action="Index">Към работния плот</a>
                    <span class="head-auth-user" title="@User.Identity!.Name">@User.Identity!.Name</span>
                    <form asp-area="Identity" asp-controller="Account" asp-action="Logout" method="post" class="head-auth-form">
                        <button type="submit" class="head-auth-link">Изход</button>
                    </form>
                }
                else
                {
                    <a class="head-auth-link" asp-area="Identity" asp-controller="Account" asp-action="Login">Вход</a>
                    <a class="head-auth-link head-auth-link-primary" asp-area="Identity" asp-controller="Account" asp-action="Register">Регистрация</a>
                }
            </nav>
        </div>
    </header>

    <main id="main">
        @RenderBody()
    </main>

    <footer class="site-foot">
        <div class="container foot-inner">
            <span>© @DateTime.Now.Year accountant</span>
            <span class="muted">AI автоматизация за счетоводни офиси</span>
        </div>
    </footer>
</body>
</html>
