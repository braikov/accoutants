@{
    ViewData["Title"] = "Coming soon";
}

<section class="hero">
    <div class="container hero-inner">
        <span class="eyebrow">Скоро</span>
        <h1 class="hero-title">
            AI автоматизация<br />
            за счетоводни офиси
        </h1>
        <p class="hero-lead">
            Подавате PDF, снимка или скан на документа.<br />
            Получавате структурирани данни, готови за импорт.<br />
            Без ръчно въвеждане. Без чакане. Без грешки от умора.
        </p>
        <div class="cta-row">
            <a class="cta-primary" href="tel:+359000000000">
                <span class="cta-label">Позвънете за демо</span>
                <span class="cta-phone">+359 00 000 0000</span>
            </a>
            <p class="cta-tagline">Бързо. Лесно. Точно.</p>
        </div>
    </div>
</section>

<section class="demo">
    <div class="container">
        <header class="section-head">
            <span class="eyebrow">Извличане на документ</span>
            <h2 class="section-title">Едно качване — пълен запис</h2>
        </header>

        <article class="demo-card" aria-label="Примерно извличане на фактура">
            <header class="demo-card-head">
                <div>
                    <span class="muted">Фактура</span>
                    <h3>0000300823</h3>
                </div>
                <div class="status-pill ok">
                    <span class="dot" aria-hidden="true"></span>
                    Готово за импорт
                </div>
            </header>

            <div class="metric-grid">
                <div class="metric">
                    <span class="metric-value">98.9<span class="metric-unit">%</span></span>
                    <span class="metric-label">точност на полетата</span>
                </div>
                <div class="metric">
                    <span class="metric-value">7<span class="metric-unit">сек</span></span>
                    <span class="metric-label">време за обработка</span>
                </div>
                <div class="metric">
                    <span class="metric-value">26</span>
                    <span class="metric-label">извлечени полета</span>
                </div>
                <div class="metric">
                    <span class="metric-value check" aria-hidden="true">✓</span>
                    <span class="metric-label">съвпадение по плащане</span>
                </div>
            </div>

            <div class="demo-actions">
                <button type="button" class="cta-secondary" disabled>
                    Изтегли импорт-файл
                    <span class="muted small">.xml</span>
                </button>
                <span class="muted small">Демо изглед — реалните стойности зависят от документа.</span>
            </div>
        </article>

        <ul class="value-grid">
            <li>
                <h3>Една точка на въвеждане</h3>
                <p>Фактури, касови бележки, проформи, протоколи — един общ контракт за всички видове документи.</p>
            </li>
            <li>
                <h3>Сравним резултат от три AI</h3>
                <p>Паралелна екстракция с три модела и автоматично сравнение — виждате различията преди да импортирате.</p>
            </li>
            <li>
                <h3>Готов за вашия счетоводен софтуер</h3>
                <p>Експорт като XML / JSON / CSV в шаблона на най-разпространените български програми.</p>
            </li>
        </ul>
    </div>
</section>
