@model Accountant.Email.Models.PasswordChangedModel
@{
    Layout = "_EmailLayout";
}

<h2 style="margin:0 0 16px;font-size:20px;letter-spacing:-.01em;color:#0f172a;">Паролата е променена</h2>

<p style="margin:0 0 12px;">Здравейте,</p>

<p style="margin:0 0 16px;">Информираме ви, че паролата на акаунта <strong>@Model.Email</strong> току-що беше променена.</p>

<table role="presentation" style="width:100%;margin:16px 0;border-collapse:collapse;font-size:14px;">
    <tr>
        <td style="padding:8px 0;border-bottom:1px solid #e5e7eb;font-weight:600;width:140px;color:#0f172a;">Време:</td>
        <td style="padding:8px 0;border-bottom:1px solid #e5e7eb;color:#334155;">@Model.FormattedChangedAt UTC</td>
    </tr>
    @if (!string.IsNullOrWhiteSpace(Model.IpAddress))
    {
        <tr>
            <td style="padding:8px 0;border-bottom:1px solid #e5e7eb;font-weight:600;color:#0f172a;">IP адрес:</td>
            <td style="padding:8px 0;border-bottom:1px solid #e5e7eb;color:#334155;">@Model.IpAddress</td>
        </tr>
    }
</table>

<div style="margin-top:24px;padding:14px 16px;background:#fef2f2;border-left:4px solid #b91c1c;border-radius:4px;color:#991b1b;font-size:13px;line-height:1.5;">
    <strong>Ако не сте вие:</strong> някой може да е получил достъп до акаунта ви. Моля незабавно нулирайте паролата отново и се свържете с поддръжката.
</div>
