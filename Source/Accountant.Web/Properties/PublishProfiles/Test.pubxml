<?xml version="1.0" encoding="utf-8"?>
<!--
  Test deployment profile for Accountant.Web -> accountant.ima.bg
  on the vic.bg IIS server via Web Deploy (WMSVC).

  The deploy account password should be stored locally in Test.pubxml.user
  (encrypted by Visual Studio after one-time "Save password" in Publish dialog),
  or passed explicitly to MSDeploy via /p:Password=...

  Production connection string is configured as an IIS App Pool environment variable
  on the server (`ConnectionStrings__Accountant`), NOT in this profile or in
  appsettings.Production.json.
-->
<Project>
  <PropertyGroup>
    <WebPublishMethod>MSDeploy</WebPublishMethod>
    <LaunchSiteAfterPublish>false</LaunchSiteAfterPublish>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <SiteUrlToLaunchAfterPublish>https://accountant.ima.bg/</SiteUrlToLaunchAfterPublish>
    <ExcludeApp_Data>true</ExcludeApp_Data>
    <SelfContained>false</SelfContained>
    <MSDeployServiceURL>vic.bg:8172</MSDeployServiceURL>
    <DeployIisAppPath>accountant.ima.bg</DeployIisAppPath>
    <RemoteSitePhysicalPath />
    <SkipExtraFilesOnServer>true</SkipExtraFilesOnServer>
    <MSDeployPublishMethod>WMSVC</MSDeployPublishMethod>
    <EnableMSDeployBackup>true</EnableMSDeployBackup>
    <EnableMsDeployAppOffline>true</EnableMsDeployAppOffline>
    <UserName>WIN-5DK51C7DFUB\deploy</UserName>
    <_SavePWD>true</_SavePWD>
    <_TargetId>IISWebDeploy</_TargetId>
    <TargetFramework>net10.0</TargetFramework>
    <ProjectGuid>fcedb2da-64c5-464a-8a44-3994e8548523</ProjectGuid>
    <EnvironmentName>Test</EnvironmentName>
  </PropertyGroup>
</Project>
