<?xml version="1.0" encoding="utf-8"?>
<!--
  Repo-local NuGet config.
    1. nuget.org for public packages.
    2. braikov-local for Braikov.Notifications.* (built locally from
       C:/Projects/Miro/Braikov via `dotnet pack`; .nupkg files land in
       C:/Projects/Miro/NuGet/). See Braikov repo README for the update
       workflow. The path is absolute on purpose — this folder is shared
       across sibling repos (Assistant, Accountant, ...).
  Excludes any user-level sources (e.g. unreachable corporate shares).
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="braikov-local" value="C:\Projects\Miro\NuGet" />
  </packageSources>
</configuration>
