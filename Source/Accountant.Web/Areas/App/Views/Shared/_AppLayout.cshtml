@inject Accountant.Web.Areas.App.Services.IActiveTenantAccessor ActiveTenant
@inject Accountant.Web.Areas.App.Services.TenantService Tenants
@{
    var title = ViewData["Title"] as string;
    var fullTitle = string.IsNullOrEmpty(title) ? "Accountant" : $"{title} — Accountant";
    int userId = int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value, System.Globalization.CultureInfo.InvariantCulture);
    var memberships = await Tenants.ListMembershipsAsync(userId, Context.RequestAborted);
    var active = ActiveTenant.Current;
}
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0f172a" />
    <title>@fullTitle</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="~/app/css/app.css" asp-append-version="true" />
</head>
<body>
    <header class="app-head">
        <div class="app-container head-inner">
            <a class="brand" href="@Url.Action("Index", "Home", new { area = "App" })" aria-label="Accountant">
                <span class="brand-mark" aria-hidden="true">a.</span>
                <span class="brand-name">accountant</span>
            </a>
            <nav class="head-nav" aria-label="Акаунт">
                @if (active is not null)
                {
                    <details class="tenant-switcher">
                        <summary class="tenant-switcher-summary" title="Активна фирма">
                            <span class="tenant-switcher-name">@active.Name</span>
                            <span class="tenant-switcher-caret" aria-hidden="true">▾</span>
                        </summary>
                        <div class="tenant-switcher-menu">
                            @foreach (var m in memberships)
                            {
                                <form asp-area="App" asp-controller="Tenants" asp-action="Switch" method="post" class="tenant-switcher-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="tenantId" value="@m.Id" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                    <button type="submit" class="tenant-switcher-item @(m.Id == active.Id ? "is-active" : "")">@m.Name</button>
                                </form>
                            }
                            <a asp-area="App" asp-controller="Tenants" asp-action="Create" class="tenant-switcher-item tenant-switcher-create">+ Нова фирма</a>
                        </div>
                    </details>
                }
                <span class="head-nav-user" title="@User.Identity!.Name">@User.Identity!.Name</span>
                <a class="head-nav-link" asp-area="Identity" asp-controller="Account" asp-action="ChangePassword">Смяна на парола</a>
                <form asp-area="Identity" asp-controller="Account" asp-action="Logout" method="post" class="head-nav-form">
                    <button type="submit" class="head-nav-link">Изход</button>
                </form>
            </nav>
        </div>
    </header>

    <main class="app-main">
        <div class="app-container">
            @RenderBody()
        </div>
    </main>

    <footer class="app-foot">
        <div class="app-container foot-inner">
            <span>© @DateTime.Now.Year accountant</span>
            <span class="muted">AI автоматизация за счетоводни офиси</span>
        </div>
    </footer>
</body>
</html>
