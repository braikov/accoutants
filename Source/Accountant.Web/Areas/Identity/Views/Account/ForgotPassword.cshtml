@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Забравена парола";
}

<div class="auth-card">
    <h1>Забравена парола</h1>
    <p class="lead">Въведете имейла на акаунта си — ще ви изпратим линк за нулиране на паролата.</p>

    <form asp-action="ForgotPassword" method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <div class="field">
            <label asp-for="Email"></label>
            <input asp-for="Email" autocomplete="email" autofocus />
            <span asp-validation-for="Email" class="field-validation-error"></span>
        </div>

        <button type="submit" class="btn btn-primary">Изпрати линк за нулиране</button>
    </form>

    <div class="auth-meta">
        <a asp-action="Login">Назад към вход</a>
    </div>
</div>
