<?xml version="1.0" encoding="utf-8"?>
<!--
  Repo-local NuGet config. Restricts package sources to nuget.org so
  developers with extra sources in their user-level config (e.g. an
  unreachable corporate share like \\bgsvn01\ShoogerLocalNuGetRepo)
  can restore without machine-specific failures.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
