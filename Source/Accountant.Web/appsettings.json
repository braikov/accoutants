{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Identity": {
    "Cookie": {
      "Name": ".Accountant.Auth",
      "ExpireTimeSpanDays": 14,
      "SlidingExpiration": true,
      "LoginPath": "/Identity/Account/Login",
      "LogoutPath": "/Identity/Account/Logout",
      "AccessDeniedPath": "/Identity/Account/AccessDenied"
    },
    "Password": {
      "RequiredLength": 8,
      "RequireDigit": true,
      "RequireLowercase": true,
      "RequireUppercase": false,
      "RequireNonAlphanumeric": false
    },
    "User": {
      "RequireUniqueEmail": true
    },
    "SignIn": {
      "RequireConfirmedAccount": true
    },
    "Lockout": {
      "MaxFailedAccessAttempts": 5,
      "DefaultLockoutTimeSpanMinutes": 5
    }
  },
  "Email": {
    "Enabled": false,
    "DefaultCulture": "bg-BG",
    "From": {
      "Email": "no-reply@accountant.local",
      "DisplayName": "accountant"
    },
    "Smtp": {
      "Host": "",
      "Port": 587,
      "EnableSsl": true,
      "AllowInvalidCertificate": false,
      "SecureSocketOptions": "StartTls",
      "Username": "",
      "Password": ""
    }
  },
  "Notifications": {
    "DefaultCulture": "bg-BG"
  },
  "Storage": {
    "Root": "App_Data/uploads",
    "ThumbnailWidth": 240
  },
  "Hangfire": {
    "DashboardPath": "/Administration/Hangfire"
  },
  "Extraction": {
    "DefaultVendor": "codex"
  }
}
